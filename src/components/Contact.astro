---
import LiquidLink from './LiquidLink';
---

<section id="contact" class="mt-20 border-t border-[#d6b05c]/15 py-14 sm:mt-24 sm:py-16">
  <p class="text-xs uppercase tracking-[0.35em] text-[#d6b05c] sm:text-sm">Contact</p>

  <div class="mt-4 grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
    <div>
      <h2 class="text-2xl font-bold leading-tight text-[#fff8df] sm:text-3xl">Bring René to your operation.</h2>

      <p class="mt-4 max-w-2xl leading-7 text-[#c7bda8]">
        For demos, pilots, and implementation planning.
      </p>
    </div>

    <LiquidLink href="mailto:rene@example.com" size="wide" client:load>
      Email
    </LiquidLink>
  </div>
</section>
